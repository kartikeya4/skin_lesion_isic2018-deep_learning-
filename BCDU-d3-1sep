='he_normal')(pool2)\n    conv3 = BatchNormalization(axis=3, epsilon=1e-3)(conv3)\n    conv3 = Activation('relu')(conv3)\n    \n    conv3 = Conv2D(256, 3, padding='same', kernel_initializer='he_normal')(conv3)\n    conv3 = BatchNormalization(axis=3, epsilon=1e-3)(conv3)\n    conv3 = Activation('relu')(conv3)\n    \n    drop3 = Dropout(0.5)(conv3)\n    pool3 = MaxPooling2D(pool_size=(2, 2))(drop3)\n    #D1\n    conv4 = Conv2D(512, 3, padding='same', kernel_initializer='he_normal')(pool3)\n    conv4 = BatchNormalization(axis=3, epsilon=1e-3)(conv4)\n    conv4 = Activation('relu')(conv4)\n   \n    conv4_1 = Conv2D(512, 3, padding='same', kernel_initializer='he_normal')(conv4)\n    conv4_1 = BatchNormalization(axis=3, epsilon=1e-3)(conv4_1)\n    conv4_1 = Activation('relu')(conv4_1)\n    drop4_1 = Dropout(0.5)(conv4_1)\n     # D2\n        \n    conv4_2 = Conv2D(512, 3, padding='same', kernel_initializer='he_normal')(drop4_1)\n    conv4_2= BatchNormalization(axis=3, epsilon=1e-3)(conv4_2)\n    conv4_2 = Activation('relu')(conv4_2)\n   \n    conv4_2 = Conv2D(512, 3, padding='same', kernel_initializer='he_normal')(conv4_2)\n    conv4_2 = BatchNormalization(axis=3, epsilon=1e-3)(conv4_2)\n    conv4_2 = Activation('relu')(conv4_2)\n    drop4_2 = Dropout(0.5)(conv4_2)\n    \n    # D3\n    merge_dense = concatenate([conv4_2,drop4_1], axis = 3)    \n    conv4_3 = Conv2D(512, 3, padding='same', kernel_initializer='he_normal')(merge_dense)\n    conv4_3= BatchNormalization(axis=3, epsilon=1e-3)(conv4_3)\n    conv4_3 = Activation('relu')(conv4_3)\n   \n    conv4_3 = Conv2D(512, 3, padding='same', kernel_initializer='he_normal')(conv4_3)\n    conv4_3 = BatchNormalization(axis=3, epsilon=1e-3)(conv4_3)\n    conv4_3 = Activation('relu')(conv4_3)\n    drop4_3 = Dropout(0.5)(conv4_3)\n\n    \n    up6 = Conv2DTranspose(256, kernel_size=2, strides=2, padding='same', kernel_initializer='he_normal')(drop4_3)\n    up6 = BatchNormalization(axis=3, epsilon=1e-3)(up6)\n    up6 = Activation('relu')(up6)\n\n    x1 = Reshape(target_shape=(1, np.int32(N/4), np.int32(N/4), 256))(drop3)\n    x2 = Reshape(target_shape=(1, np.int32(N/4), np.int32(N/4), 256))(up6)\n    merge6 = concatenate([x1, x2], axis=1) \n    merge6 = ConvLSTM2D(filters=128, kernel_size=(3, 3), padding='same', return_sequences=False, go_backwards=True, kernel_initializer='he_normal')(merge6)\n            \n    conv6 = Conv2D(256, 3, padding='same', kernel_initializer='he_normal')(merge6)\n    conv6 = BatchNormalization(axis=3, epsilon=1e-3)(conv6)\n    conv6 = Activation('relu')(conv6)\n    \n    conv6 = Conv2D(256, 3, padding='same', kernel_initializer='he_normal')(conv6)\n    conv6 = BatchNormalization(axis=3, epsilon=1e-3)(conv6)\n    conv6 = Activation('relu')(conv6)\n\n    up7 = Conv2DTranspose(128, kernel_size=2, strides=2, padding='same', kernel_initializer='he_normal')(conv6)\n    up7 = BatchNormalization(axis=3, epsilon=1e-3)(up7)\n    up7 = Activation('relu')(up7)\n\n    x1 = Reshape(target_shape=(1, np.int32(N/2), np.int32(N/2), 128))(conv2)\n    x2 = Reshape(target_shape=(1, np.int32(N/2), np.int32(N/2), 128))(up7)\n    merge7 = concatenate([x1, x2], axis=1) \n    merge7 = ConvLSTM2D(filters=64, kernel_size=(3, 3), padding='same', return_sequences=False, go_backwards=True, kernel_initializer='he_normal')(merge7)\n        \n    conv7 = Conv2D(128, 3, padding='same', kernel_initializer='he_normal')(merge7)\n    conv7 = BatchNormalization(axis=3, epsilon=1e-3)(conv7)\n    conv7 = Activation('relu')(conv7)\n    \n    conv7 = Conv2D(128, 3, padding='same', kernel_initializer='he_normal')(conv7)\n    conv7 = BatchNormalization(axis=3, epsilon=1e-3)(conv7)\n    conv7 = Activation('relu')(conv7)\n\n    up8 = Conv2DTranspose(64, kernel_size=2, strides=2, padding='same', kernel_initializer='he_normal')(conv7)\n    up8 = BatchNormalization(axis=3, epsilon=1e-3)(up8)\n    up8 = Activation('relu')(up8)    \n\n    x1 = Reshape(target_shape=(1, N, N, 64))(conv1)\n    x2 = Reshape(target_shape=(1, N, N, 64))(up8)\n    merge8 = concatenate([x1, x2], axis=1) \n    merge8 = ConvLSTM2D(filters=32, kernel_size=(3, 3), padding='same', return_sequences=False, go_backwards=True, kernel_initializer='he_normal')(merge8)    \n    \n    conv8 = Conv2D(64, 3, padding='same', kernel_initializer='he_normal')(merge8)\n    conv8 = BatchNormalization(axis=3, epsilon=1e-3)(conv8)\n    conv8 = Activation('relu')(conv8)\n    \n    conv8 = Conv2D(64, 3, padding='same', kernel_initializer='he_normal')(conv8)\n    conv8 = BatchNormalization(axis=3, epsilon=1e-3)(conv8)\n    conv8 = Activation('relu')(conv8)\n    \n    conv8 = Conv2D(2, 3, padding='same', kernel_initializer='he_normal')(conv8)\n    conv9 = Conv2D(1, 1, activation='sigmoid')(conv8)\n\n    model = Model(inputs=inputs, outputs=conv9)\n    \n    # Compile the model\n    model.compile(optimizer=Adam(learning_rate=1e-5, clipnorm=1.0), loss='binary_crossentropy', metrics=['accuracy'])\n\n    return model\n","metadata":{"execution":{"iopub.status.busy":"2024-09-02T10:51:37.199563Z","iopub.execute_input":"2024-09-02T10:51:37.200414Z","iopub.status.idle":"2024-09-02T10:51:50.616492Z","shell.execute_reply.started":"2024-09-02T10:51:37.200348Z","shell.execute_reply":"2024-09-02T10:51:50.615654Z"},"trusted":true},"outputs":[{"name":"stderr","text":"2024-09-02 10:51:39.101472: E external/local_xla/xla/stream_executor/cuda/cuda_dnn.cc:9261] Unable to register cuDNN factory: Attempting to register factory for plugin cuDNN when one has already been registered\n2024-09-02 10:51:39.101606: E external/local_xla/xla/stream_executor/cuda/cuda_fft.cc:607] Unable to register cuFFT factory: Attempting to register factory for plugin cuFFT when one has already been registered\n2024-09-02 10:51:39.239823: E external/local_xla/xla/stream_executor/cuda/cuda_blas.cc:1515] Unable to register cuBLAS factory: Attempting to register factory for plugin cuBLAS when one has already been registered\n","output_type":"stream"}],"execution_count":2},{"cell_